NODE_ENV=development
PORT=5000
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# MongoDB Atlas: add 0.0.0.0/0 to Network Access if connection fails
# Or use local: MONGO_URI=mongodb://localhost:27017/worqhub
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/worqhub

CORS_ORIGIN=http://localhost:3000
